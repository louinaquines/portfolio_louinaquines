# Site Configuration
# Copy this file to .env and fill in your values
# Required: Your site URL (used for sitemap, canonical URLs, OG tags)
SITE_URL=https://example.com

# Site language (ISO 639-1 code, e.g., en, id, de, fr, es, ja, zh)
SITE_LANGUAGE=en

# Personal Information
SITE_AUTHOR_NAME="Your Name"
SITE_AUTHOR_TITLE="Senior Software Engineer"
SITE_AUTHOR_BIO="Engineering leader focused on solving complex technical challenges through thoughtful architecture and pragmatic trade-off analysis."
SITE_AUTHOR_EMAIL=hello@example.com
SITE_AUTHOR_LOCATION="San Francisco, CA"

# Social Links (leave empty to hide)
SOCIAL_GITHUB=https://github.com/username
SOCIAL_LINKEDIN=https://linkedin.com/in/username
SOCIAL_TWITTER=https://twitter.com/username
SOCIAL_MASTODON=
SOCIAL_BLUESKY=

# Site Metadata
SITE_TITLE="Professional Portfolio"
SITE_DESCRIPTION="Engineering leader specializing in system architecture, technical decision-making, and delivering measurable business impact."

# Telegram Configuration (for receiving chat notifications)
# Get your bot token from @BotFather on Telegram
# Get your chat ID from @userinfobot or @myidbot on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# After deploying to Vercel, run: npm run set-webhook
# This will configure Telegram to send replies to your website
