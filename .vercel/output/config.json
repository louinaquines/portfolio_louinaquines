{
	"version": 3,
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/404/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/ai-fallback/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/chat/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/reply/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/telegram-webhook/?$",
			"dest": "_render"
		},
		{
			"src": "^/contact/?$",
			"dest": "_render"
		},
		{
			"src": "^/decisions/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/decisions/?$",
			"dest": "_render"
		},
		{
			"src": "^/journey/?$",
			"dest": "_render"
		},
		{
			"src": "^/projects/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/projects/?$",
			"dest": "_render"
		},
		{
			"src": "^/robots\\.txt/?$",
			"dest": "_render"
		},
		{
			"src": "^/speaking/?$",
			"dest": "_render"
		},
		{
			"src": "^/uses/?$",
			"dest": "_render"
		},
		{
			"src": "^/writing/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/writing(?:/(.*?))?/?$",
			"dest": "_render"
		},
		{
			"src": "^/$",
			"dest": "_render"
		},
		{
			"src": "^/.*$",
			"dest": "_render",
			"status": 404
		}
	]
}