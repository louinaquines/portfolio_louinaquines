---
/**
 * Home Page - Loui Jay Naquines Portfolio
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import SEO from '../components/SEO.astro';
import StructuredData from '../components/StructuredData.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import profileImage from '../assets/profile1.jpg';
import photo from '../assets/profile.jpg';
import photo2 from '../assets/pic2.jpg';
import photo3 from '../assets/pic3.jpg';
import photo4 from '../assets/pic4.jpg';
import photo5 from '../assets/pic1.jpg';
import photo6 from '../assets/pic5.jpg';



const allProjects = await getCollection('projects');
const featuredProjects = allProjects
  .filter(p => p.data.featured === true)
  .sort((a, b) => (a.data.order || 999) - (b.data.order || 999))
  .slice(0, 4);


const techStack = {
  Frontend: [
    { name: "React",       icon: "https://cdn.simpleicons.org/react/61DAFB" },
    { name: "Astro",       icon: "https://cdn.simpleicons.org/astro/FF5D01" },
    { name: "TypeScript",  icon: "https://cdn.simpleicons.org/typescript/3178C6" },
    { name: "Tailwind CSS", icon: "https://cdn.simpleicons.org/tailwindcss/06B6D4" },
    { name: "Next.js",      icon: "https://cdn.simpleicons.org/nextdotjs/000000" },
  ],
  Backend: [
    { name: "Node.js",   icon: "https://cdn.simpleicons.org/nodedotjs/339933" },
    { name: "Express",   icon: "https://cdn.simpleicons.org/express/000000" },
    { name: "PHP",       icon: "https://cdn.simpleicons.org/php/777BB4" },
    { name: "REST APIs", icon: "https://cdn.simpleicons.org/fastapi/05998B" },
  ],
  Database: [
    { name: "PostgreSQL", icon: "https://cdn.simpleicons.org/postgresql/4169E1" },
    { name: "MySQL",      icon: "https://cdn.simpleicons.org/mysql/4479A1" },
    { name: "MongoDB",    icon: "https://cdn.simpleicons.org/mongodb/47A248" },
    { name: "Supabase",   icon: "https://cdn.simpleicons.org/supabase/3ECF8E" },
  ],
  Tools: [
    { name: "Git",    icon: "https://cdn.simpleicons.org/git/F05032" },
    { name: "Docker", icon: "https://cdn.simpleicons.org/docker/2496ED" },
    { name: "Figma",  icon: "https://cdn.simpleicons.org/figma/F24E1E" },
    { name: "Vercel", icon: "https://cdn.simpleicons.org/vercel/000000" },
  ],
};

const galleryImages = [
  { src: photo,  alt: "Photo 1" },
  { src: photo2, alt: "Photo 2" },
  { src: photo3, alt: "Photo 3" },
  { src: photo4, alt: "Photo 4" },
  { src: photo5, alt: "Photo 5" },
  { src: photo6, alt: "Photo 6" },
];
---

<BaseLayout>
  <SEO
    slot="head"
    title="Loui Jay Naquines — Full Stack Developer"
    description="Full stack developer and CS student based in Mandaue City, Cebu."
    type="website"
    noSuffix
  />
  <StructuredData type="WebSite" />
  <StructuredData type="Person" />

  <main class="page">

    <!-- ── PAGE LOADER ── -->
    <div id="page-loader" class="page-loader">
      <div class="loader-content">
        <div class="loader-logo">LN</div>
        <div class="loader-bar"><div class="loader-bar-fill"></div></div>
      </div>
    </div>

    <!-- ── PROFILE HEADER ── -->
    <header class="profile-header reveal reveal-up">
      <div class="profile-header-inner">
        <Image src={profileImage} alt="Loui Jay Naquines" class="avatar" />
        <div class="profile-info">
          <div class="profile-name-row">
            <h1 class="profile-name">Loui Jay Naquines</h1>
          </div>
          <p class="profile-location">Mandaue City, Cebu</p>
          <p class="profile-role">Full Stack Developer · IT Student</p>
          <div class="profile-actions">
            <button id="open-projects-modal" class="btn-secondary btn-schedule-trigger">🚀 View My Latest Project</button>
            <button id="open-hire-modal" class="btn-secondary btn-schedule-trigger">💼 Hire Me for Freelance</button>
          </div>
        </div>
      </div>
    </header>

    <!-- ── MAIN GRID ── -->
    <div class="main-grid">

      <!-- LEFT COLUMN -->
      <div class="col-left">

        <!-- ABOUT -->
        <section id="about" class="card reveal reveal-up" style="scroll-margin-top:5rem; animation-delay: 0.1s">
          <h2 class="card-title"><svg class="card-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>About</h2>
          <p>
            I'm a Information Technology student passionate about building end-to-end web applications. I don't just ship features — I think about architecture, trade-offs, and long-term maintainability.
          </p>
          <p>
            Currently looking for a junior developer role where I can contribute to real products and grow alongside experienced engineers. Based in Cebu, open to remote.
          </p>
        </section>

        <!-- TECH STACK -->
        <section id="stack" class="card reveal reveal-up" style="scroll-margin-top:5rem; animation-delay:0.15s">
          <div class="card-title-row">
            <h2 class="card-title"><svg class="card-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M12 2v2M12 20v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M2 12h2M20 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>Tech Stack</h2>
            <button class="view-all" id="open-stack-modal">View All &rsaquo;</button>
          </div>
          {Object.entries(techStack).map(([category, tools]) => (
            <div class="stack-group">
              <h3 class="stack-category">{category}</h3>
              <div class="stack-tags">
                {tools.map(tool => (
                  <span class="tag">
                    <img src={tool.icon} alt={tool.name} class="tag-icon" width="13" height="13" loading="lazy" />
                    {tool.name}
                  </span>
                ))}
              </div>
            </div>
          ))}
        </section>

        <!-- RECENT PROJECTS -->
        <section class="card reveal reveal-up" style="animation-delay:0.2s">
          <div class="card-title-row">
            <h2 class="card-title"><svg class="card-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7a2 2 0 0 1 2-2h4l2 2h8a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>Recent Projects</h2>
            <button class="view-all" id="open-projects-modal-alt">View All &rsaquo;</button>
          </div>
          <div class="projects-grid">
            {false ? featuredProjects.map(project => (
              <a href={`/projects/${project.id}`} class="project-card">
                <span class="project-role">{project.data.role}</span>
                <h3 class="project-title">{project.data.title}</h3>
                <p class="project-desc">{project.data.outcomeSummary}</p>
              </a>
            )) : (
              <>
                <a href="https://pagkainang-sambayanan-production.up.railway.app/" class="project-card">
                  <span class="project-role">Full Stack Developer</span>
                  <h3 class="project-title">Pagkainang-Sambayanan</h3>
                  <p class="project-desc">Bridging surplus food with communities in need</p>
                </a>
              </>
            )}
          </div>
        </section>

        <!-- GALLERY -->
        <section class="card reveal reveal-up" style="animation-delay:0.25s">
          <h2 class="card-title"><svg class="card-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>Gallery</h2>
          <p class="card-sub">Some photos of me.</p>
          <div class="gallery-grid">
            {galleryImages.map((img, i) => (
              <div class="gallery-item" data-index={i}>
                {img.src ? (
                  <img src={img.src.src ?? img.src} alt={img.alt} class="gallery-img" loading="lazy" />
                ) : (
                  <div class="gallery-placeholder"><span>📷</span></div>
                )}
              </div>
            ))}
          </div>
        </section>

      </div>

      <!-- RIGHT COLUMN -->
      <div class="col-right">

        <!-- EXPERIENCE -->
        <section class="card reveal reveal-left" style="animation-delay:0.1s">
          <div class="card-title-row">
            <h2 class="card-title"><svg class="card-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/></svg>Experience</h2>
            <button class="view-all" id="open-experience-modal">View All &rsaquo;</button>
          </div>
          <div class="timeline">
            <div class="timeline-item">
              <div class="timeline-dot active"></div>
              <div class="timeline-body">
                <span class="timeline-year">2024 — Present</span>
                <strong>Freelance Full Stack Developer</strong>
                <p>Building and deploying web solutions for local clients.</p>
              </div>
            </div>
            <div class="timeline-item">
              <div class="timeline-dot"></div>
              <div class="timeline-body">
                <span class="timeline-year">2023 — Present</span>
                <strong>IT Student</strong>
                <p>Studying algorithms, system design, and software engineering.</p>
              </div>
            </div>
          </div>
        </section>

        <!-- GOALS -->
        <section class="card reveal reveal-left" style="animation-delay:0.15s">
          <h2 class="card-title"><svg class="card-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>Goals</h2>
          <div class="goals-list">
            <div class="goal-item">
              <strong>Land My First Dev Role</strong>
              <p>Looking for a junior position to contribute, learn, and grow fast.</p>
            </div>
            <div class="goal-item">
              <strong>Ship a SaaS Product</strong>
              <p>Take an idea from zero to paying users — owning the full stack.</p>
            </div>
            <div class="goal-item">
              <strong>Go Deeper on System Design</strong>
              <p>Understand how systems scale, where they break, and how to build for longevity.</p>
            </div>
            <div class="goal-item">
              <strong>Build in Public</strong>
              <p>Document projects and decisions openly to track growth and help others.</p>
            </div>
          </div>
        </section>

        <!-- CONTACT SECTION -->
        <section id="contact" class="card reveal reveal-left" style="scroll-margin-top:5rem; animation-delay:0.2s">
          <h2 class="card-title">
            <svg class="card-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 14a9 9 0 1 0-5.23 9.09"/><path d="M12 10v3"/></svg>
            Let's Connect
          </h2>
          <p class="card-sub">Have a project in mind? I'd love to hear about it.</p>
          
          <div class="contact-list">
            <li>
              <div class="contact-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
              </div>
              <div>
                <span class="contact-label">GitHub</span>
                <a href="https://github.com/louinaquines" target="_blank" rel="noopener" class="contact-value">@louinaquines</a>
              </div>
            </li>
            <li>
              <div class="contact-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
              </div>
              <div>
                <span class="contact-label">LinkedIn</span>
                <a href="https://linkedin.com/in/louinaquines" target="_blank" rel="noopener" class="contact-value">louinaquines</a>
              </div>
            </li>
            <li>
              <div class="contact-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              </div>
              <div>
                <span class="contact-label">Email</span>
                <a href="mailto:louinaquines@gmail.com" class="contact-value">louinaquines@gmail.com</a>
              </div>
            </li>
          </div>

          <!-- Recent Certifications (Empty - matching gallery length) -->
          <div class="certifications-section" style="min-height: 200px;">
          </div>
        </section>

      </div>
    </div>
  </main>

  <!-- ── TECH STACK MODAL ── -->
  <div class="modal-overlay" id="stack-modal">
    <div class="modal-backdrop" id="stack-modal-backdrop"></div>
    <div class="modal-panel">
      <div class="modal-header">
        <h2 class="modal-title">
          <svg class="card-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M12 2v2M12 20v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M2 12h2M20 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
          Full Tech Stack
        </h2>
        <button class="modal-close" id="close-stack-modal" aria-label="Close">&times;</button>
      </div>
      <div class="modal-body">
        {Object.entries(techStack).map(([category, tools]) => (
          <div class="modal-stack-group">
            <h3 class="modal-stack-category">{category}</h3>
            <div class="stack-tags">
              {tools.map(tool => (
                <span class="tag">
                  <img src={tool.icon} alt={tool.name} class="tag-icon" width="13" height="13" loading="lazy" />
                  {tool.name}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- ── EXPERIENCE MODAL ── -->
  <div class="modal-overlay" id="experience-modal">
    <div class="modal-backdrop" id="experience-modal-backdrop"></div>
    <div class="modal-panel modal-panel--narrow">
      <div class="modal-header">
        <h2 class="modal-title">
          <svg class="card-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/></svg>
          Full Experience
        </h2>
        <button class="modal-close" id="close-experience-modal" aria-label="Close">&times;</button>
      </div>
      <div class="modal-body">
        <div class="timeline">
          <div class="timeline-item">
            <div class="timeline-dot active"></div>
            <div class="timeline-body">
              <span class="timeline-year">2024 — Present</span>
              <strong>Freelance Full Stack Developer</strong>
              <p>Building and deploying web solutions for local clients. Working on real-world projects end-to-end, from design to deployment.</p>
            </div>
          </div>
          <div class="timeline-item">
            <div class="timeline-dot"></div>
            <div class="timeline-body">
              <span class="timeline-year">2023 — Present</span>
              <strong>IT Student</strong>
              <p>Studying algorithms, system design, and software engineering principles. Applying academic knowledge to real projects.</p>
            </div>
          </div>
          <div class="timeline-item">
            <div class="timeline-dot"></div>
            <div class="timeline-body">
              <span class="timeline-year">2022</span>
              <strong>Started Learning Development</strong>
              <p>Began self-studying web development — HTML, CSS, JavaScript, and basic backend concepts.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ── VIEW MY LATEST PROJECT MODAL ── -->
  <div class="modal-overlay" id="projects-modal">
    <div class="modal-backdrop" id="projects-modal-backdrop"></div>
    <div class="modal-panel modal-panel--gallery">
      <div class="modal-header">
        <h2 class="modal-title">
          <svg class="card-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7a2 2 0 0 1 2-2h4l2 2h8a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>
          View My Latest Project
        </h2>
        <button class="modal-close" id="close-projects-modal" aria-label="Close">&times;</button>
      </div>
      <div class="modal-body">
        <p class="gallery-modal-intro">Check out my latest project — a full-stack solution I built from the ground up.</p>
        
        <a href="https://pagkainang-sambayanan-production.up.railway.app/" target="_blank" rel="noopener" class="modal-project-card">
          <span class="mpc-role-badge">Full Stack Developer</span>
          <h3 class="mpc-title">Pagkainang Sambayanan</h3>
          <p class="mpc-desc">Bridging surplus food with communities in need.</p>
          <span class="mpc-tech">Laravel · MySQL · Bootstrap</span>
        </a>
      </div>
    </div>
  </div>

  <!-- ── START FREELANCE PROJECT MODAL ── -->
  <div class="modal-overlay" id="hire-modal">
    <div class="modal-backdrop" id="hire-modal-backdrop"></div>
    <div class="modal-panel modal-panel--freelance">
      <div class="modal-header">
        <h2 class="modal-title">
          <svg class="card-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/></svg>
          Start a Freelance Project
        </h2>
        <button class="modal-close" id="close-hire-modal" aria-label="Close">&times;</button>
      </div>
      <div class="modal-body">
        <p class="sc-desc">Got a project in mind? Tell me what you need and I'll get back to you within 24 hours.</p>

        <form class="sc-form" id="hire-form" novalidate>
          <div class="sc-field">
            <label class="sc-label" for="hire-name">Name</label>
            <input class="sc-input" type="text" id="hire-name" placeholder="Your name" required />
          </div>
          <div class="sc-field">
            <label class="sc-label" for="hire-email">Email</label>
            <input class="sc-input" type="email" id="hire-email" placeholder="your@email.com" required />
          </div>
          <div class="sc-field">
            <label class="sc-label" for="hire-message">Tell me about the app, website, or feature you want me to build...</label>
            <textarea class="sc-input sc-textarea" id="hire-message" rows="5" required></textarea>
          </div>
          <button type="submit" class="sc-submit" id="hire-submit">Send Request</button>
        </form>
      </div>
    </div>
  </div>

  <!-- ── LIGHTBOX ── -->
  <div class="lightbox" id="lightbox">
    <div class="lightbox-backdrop" id="lightbox-backdrop"></div>
    <button class="lightbox-close" id="lightbox-close" aria-label="Close">&times;</button>
    <button class="lightbox-prev" id="lightbox-prev" aria-label="Previous">&#8249;</button>
    <button class="lightbox-next" id="lightbox-next" aria-label="Next">&#8250;</button>
    <div class="lightbox-content">
      <img src="" alt="" class="lightbox-img" id="lightbox-img" />
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11" is:inline></script>


</BaseLayout>

<script>
  document.addEventListener('astro:page-load', () => {

    // ── PAGE LOADER ──
    const loader = document.getElementById('page-loader');
    if (loader) {
      // Always show loader on page load / reload
      loader.classList.remove('loaded');
      document.body.style.overflow = 'hidden';

      // Fill the bar then fade out
      const fill = loader.querySelector('.loader-bar-fill') as HTMLElement | null;
      if (fill) fill.style.width = '0%';

      let progress = 0;
      const interval = setInterval(() => {
        progress += Math.random() * 18 + 8;
        if (progress >= 100) {
          progress = 100;
          clearInterval(interval);
          if (fill) fill.style.width = '100%';
          setTimeout(() => {
            loader.classList.add('loaded');
            document.body.style.overflow = '';
            // Trigger reveals after loader exits
            setTimeout(initReveal, 200);
          }, 350);
        } else {
          if (fill) fill.style.width = progress + '%';
        }
      }, 80);
    } else {
      initReveal();
    }

    // ── SCROLL REVEAL ──
    function initReveal() {
      const reveals = document.querySelectorAll<HTMLElement>('.reveal');
      if (!reveals.length) return;

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            (entry.target as HTMLElement).classList.add('revealed');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });

      reveals.forEach(el => observer.observe(el));
    }

    // ── LATEST PROJECT MODAL ──
    const projectsModal     = document.getElementById('projects-modal');
    const openProjectsBtn   = document.getElementById('open-projects-modal');
    const closeProjectsBtn  = document.getElementById('close-projects-modal');
    const projectsModalBackdrop = document.getElementById('projects-modal-backdrop');
    function openProjectsModal()  { projectsModal?.classList.add('active');    document.body.style.overflow = 'hidden'; }
    function closeProjectsModal() { projectsModal?.classList.remove('active'); document.body.style.overflow = ''; }
    openProjectsBtn?.addEventListener('click', openProjectsModal);
    
    // Also handle the "View All" button in Recent Projects section
    const openProjectsAltBtn = document.getElementById('open-projects-modal-alt');
    openProjectsAltBtn?.addEventListener('click', openProjectsModal);
    
    closeProjectsBtn?.addEventListener('click', closeProjectsModal);
    projectsModalBackdrop?.addEventListener('click', closeProjectsModal);

    // ── HIRE MODAL ──
    const hireModal     = document.getElementById('hire-modal');
    const openHireBtn   = document.getElementById('open-hire-modal');
    const closeHireBtn  = document.getElementById('close-hire-modal');
    const hireBackdrop  = document.getElementById('hire-modal-backdrop');
    const hireForm      = document.getElementById('hire-form') as HTMLFormElement | null;
    function openHireModal()  { hireModal?.classList.add('active');    document.body.style.overflow = 'hidden'; }
    function closeHireModal() { hireModal?.classList.remove('active'); document.body.style.overflow = ''; }
    openHireBtn?.addEventListener('click', openHireModal);
    closeHireBtn?.addEventListener('click', closeHireModal);
    hireBackdrop?.addEventListener('click', closeHireModal);

    hireForm?.addEventListener('submit', (e) => {
      e.preventDefault();
      const submitBtn = document.getElementById('hire-submit') as HTMLButtonElement | null;
      const name    = (document.getElementById('hire-name')    as HTMLInputElement)?.value.trim()    || '';
      const email   = (document.getElementById('hire-email')   as HTMLInputElement)?.value.trim()    || '';
      const message = (document.getElementById('hire-message') as HTMLTextAreaElement)?.value.trim() || '';

      if (!name || !email || !message) {
        (window as any).Swal?.fire({
          icon: 'warning',
          title: 'Missing fields',
          text: 'Please fill in all fields before sending.',
          confirmButtonColor: '#374151',
          background: 'var(--color-bg-secondary)',
          color: 'var(--color-text)',
        });
        return;
      }

      if (submitBtn) { submitBtn.textContent = 'Sending...'; submitBtn.disabled = true; }
      const subject = encodeURIComponent(`Freelance Project Request from ${name}`);
      const body    = encodeURIComponent(`Name: ${name}\nEmail: ${email}\n\nProject Details:\n${message}`);
      window.open(`mailto:louinaquines@gmail.com?subject=${subject}&body=${body}`, '_blank');
      if (submitBtn) { submitBtn.textContent = 'Send Request'; submitBtn.disabled = false; }
      hireForm?.reset();
      closeHireModal();
      setTimeout(() => {
        (window as any).Swal?.fire({
          icon: 'success',
          title: '💼 Request Sent!',
          html: `<p style="color:var(--color-text-secondary)">Thanks, <strong>${name}</strong>! I'll review your request and reply within 24 hours.</p>`,
          confirmButtonText: 'Awesome!',
          confirmButtonColor: '#374151',
          background: 'var(--color-bg-secondary)',
          color: 'var(--color-text)',
          timer: 6000,
          timerProgressBar: true,
        });
      }, 300);
    });

    // ── TECH STACK MODAL ──
    const stackModal = document.getElementById('stack-modal');
    const openStackBtn = document.getElementById('open-stack-modal');
    const closeStackBtn = document.getElementById('close-stack-modal');
    const stackBackdrop = document.getElementById('stack-modal-backdrop');
    function openStackModal() { stackModal?.classList.add('active'); document.body.style.overflow = 'hidden'; }
    function closeStackModal() { stackModal?.classList.remove('active'); document.body.style.overflow = ''; }
    openStackBtn?.addEventListener('click', openStackModal);
    closeStackBtn?.addEventListener('click', closeStackModal);
    stackBackdrop?.addEventListener('click', closeStackModal);

    // ── EXPERIENCE MODAL ──
    const expModal = document.getElementById('experience-modal');
    const openExpBtn = document.getElementById('open-experience-modal');
    const closeExpBtn = document.getElementById('close-experience-modal');
    const expBackdrop = document.getElementById('experience-modal-backdrop');
    function openExpModal() { expModal?.classList.add('active'); document.body.style.overflow = 'hidden'; }
    function closeExpModal() { expModal?.classList.remove('active'); document.body.style.overflow = ''; }
    openExpBtn?.addEventListener('click', openExpModal);
    closeExpBtn?.addEventListener('click', closeExpModal);
    expBackdrop?.addEventListener('click', closeExpModal);

    document.addEventListener('keydown', e => {
      if (e.key === 'Escape') {
        if (projectsModal?.classList.contains('active')) closeProjectsModal();
        if (hireModal?.classList.contains('active')) closeHireModal();
        if (stackModal?.classList.contains('active')) closeStackModal();
        if (expModal?.classList.contains('active')) closeExpModal();
      }
    });

    // ── LIGHTBOX ──
    const lightbox = document.getElementById('lightbox');
    const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement | null;
    const lbClose = document.getElementById('lightbox-close');
    const prevBtn = document.getElementById('lightbox-prev');
    const nextBtn = document.getElementById('lightbox-next');
    const lbBackdrop = document.getElementById('lightbox-backdrop');

    const galleryItems = Array.from(document.querySelectorAll<HTMLElement>('.gallery-item[data-index]'));
    const images = galleryItems
      .map(item => {
        const img = item.querySelector<HTMLImageElement>('img');
        return img ? { src: img.src, alt: img.alt } : null;
      })
      .filter((x): x is { src: string; alt: string } => x !== null);

    let current = 0;

    function openLightbox(index: number) {
      if (!lightbox || !lightboxImg || !images[index]) return;
      current = index;
      lightboxImg.src = images[index].src;
      lightboxImg.alt = images[index].alt;
      lightbox.classList.add('active');
      document.body.style.overflow = 'hidden';
    }
    function closeLightbox() {
      lightbox?.classList.remove('active');
      document.body.style.overflow = '';
    }
    function showPrev() { openLightbox((current - 1 + images.length) % images.length); }
    function showNext() { openLightbox((current + 1) % images.length); }

    galleryItems.forEach(item => {
      item.addEventListener('click', () => {
        const idx = parseInt(item.getAttribute('data-index') || '0');
        if (images[idx]) openLightbox(idx);
      });
    });

    lbClose?.addEventListener('click', closeLightbox);
    lbBackdrop?.addEventListener('click', closeLightbox);
    prevBtn?.addEventListener('click', showPrev);
    nextBtn?.addEventListener('click', showNext);
    document.addEventListener('keydown', e => {
      if (!lightbox?.classList.contains('active')) return;
      if (e.key === 'Escape') closeLightbox();
      if (e.key === 'ArrowLeft') showPrev();
      if (e.key === 'ArrowRight') showNext();
    });

    // ── SCROLL & NAV ──
    const stored = sessionStorage.getItem('scrollTo');
    if (stored) {
      sessionStorage.removeItem('scrollTo');
      setTimeout(() => {
        const target = document.querySelector(stored);
        if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }, 200);
    }
    if (window.location.hash && !stored) {
      const target = document.querySelector(window.location.hash);
      if (target) {
        setTimeout(() => target.scrollIntoView({ behavior: 'smooth', block: 'start' }), 150);
      }
    }
    document.querySelectorAll('a[href^="#"]').forEach(link => {
      link.addEventListener('click', e => {
        const hash = link.getAttribute('href');
        if (!hash || hash === '#') return;
        const target = document.querySelector(hash);
        if (target) {
          e.preventDefault();
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
          history.pushState(null, '', hash);
        }
      });
    });
  });
</script>

