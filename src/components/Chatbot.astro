---
/* No server-side logic needed here — API call happens in src/pages/api/chat.ts */
---

<div class="cb-wrapper">

  <button id="cb-toggle" class="cb-toggle" aria-label="Open chat">
    <svg id="cb-icon-open" xmlns="http://www.w3.org/2000/svg" class="cb-toggle-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"></path>
    </svg>
    <span class="cb-toggle-text">Chat with Loui</span>
    <svg id="cb-icon-close" xmlns="http://www.w3.org/2000/svg" width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="display:none">
      <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
    </svg>
    <span class="cb-unread" id="cb-unread" style="display:none"></span>
  </button>

  <div id="cb-window" class="cb-window" aria-hidden="true">

    <div class="cb-header">
      <div class="cb-header-avatar">
        L
        <span class="cb-online-dot"></span>
      </div>
      <div class="cb-header-meta">
        <div class="cb-header-name">Loui's Assistant</div>
        <div class="cb-header-status" id="cb-status">online</div>
      </div>
      <button id="cb-close" class="cb-header-close" aria-label="Close">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>

    <div id="cb-messages" class="cb-messages">
      <div class="cb-date-chip">Today</div>
      <div class="cb-row cb-row-in">
        <div class="cb-bub cb-bub-in">
          Hi! 👋 I'm Loui's AI assistant. Ask me anything about his skills, projects, or experience!
          <span class="cb-time">now</span>
        </div>
      </div>
    </div>

    <div id="cb-typing" class="cb-typing-row" style="display:none">
      <div class="cb-typing-pill">
        <span></span><span></span><span></span>
      </div>
    </div>

    <div class="cb-input-bar">
      <input id="cb-input" class="cb-input" type="text" placeholder="Message..." autocomplete="off" />
      <button id="cb-send" class="cb-send" aria-label="Send">
        <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="currentColor">
          <path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/>
        </svg>
      </button>
    </div>

  </div>
</div>

<style>
  .cb-wrapper {
    position: fixed !important;
    bottom: 1.5rem !important;
    right: 1.5rem !important;
    z-index: 9999 !important;
    font-family: inherit;
    -webkit-transform: translateZ(0);
    transform: translateZ(0);
    -webkit-backface-visibility: hidden;
    backface-visibility: hidden;
  }

  /* ── Toggle ── */
  .cb-wrapper .cb-toggle {
    position: relative;
    padding: 0.75rem 1.5rem;
    border-radius: 9999px;
    background: var(--color-text);
    color: var(--color-bg);
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    box-shadow: 0 2px 6px rgba(0,0,0,0.15);
    transition: background 0.2s ease, transform 0.2s ease;
    margin: 0;
    touch-action: manipulation;
    -webkit-tap-highlight-color: transparent;
    outline: none;
  }
  .cb-wrapper .cb-toggle:hover {
    background: var(--color-accent);
  }
  :global(.dark) .cb-wrapper .cb-toggle {
    background: var(--color-bg);
    color: var(--color-text);
  }
  :global(.dark) .cb-wrapper .cb-toggle:hover {
    background: var(--color-bg-elevated);
  }
  .cb-wrapper .cb-toggle:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }
  .cb-wrapper .cb-toggle:hover {
    background: var(--color-text);
    opacity: 0.9;
  }
  :global(.dark) .cb-wrapper .cb-toggle:hover {
    background: var(--color-bg);
    opacity: 0.9;
  }
  .cb-wrapper .cb-toggle-icon {
    width: 1.50rem;
    height: 1.50rem;
    animation: cbWiggle 2s infinite;
  }
  @keyframes cbWiggle {
    0%, 100% { transform: rotate(0deg); }
    25% { transform: rotate(-10deg); }
    75% { transform: rotate(10deg); }
  }
  .cb-wrapper .cb-toggle-text {
    font-size: 0.875rem;
    font-weight: 500;
    white-space: nowrap;
  }
  .cb-wrapper .cb-unread {
    position: absolute;
    top: 4px;
    right: 4px;
    width: 10px;
    height: 10px;
    background: #ef4444;
    border-radius: 50%;
    border: 2px solid var(--color-bg);
  }

  /* ── Window ── */
  .cb-wrapper .cb-window {
    position: absolute;
    bottom: 66px;
    right: 0;
    width: 355px;
    height: 510px;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 18px;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    box-shadow: 0 12px 48px rgba(0,0,0,0.16), 0 2px 8px rgba(0,0,0,0.06);
    transform-origin: bottom right;
    transform: scale(0.88) translateY(14px);
    opacity: 0;
    pointer-events: none;
    transition: transform 0.24s cubic-bezier(0.34,1.5,0.64,1), opacity 0.18s ease;
  }
  .cb-wrapper .cb-window.open {
    transform: scale(1) translateY(0);
    opacity: 1;
    pointer-events: all;
  }

  /* ── Header ── */
  .cb-wrapper .cb-header {
    padding: 0.75rem 1rem;
    background: var(--color-bg-secondary);
    border-bottom: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    gap: 0.625rem;
    flex-shrink: 0;
  }
  .cb-wrapper .cb-header-avatar {
    position: relative;
    width: 38px;
    height: 38px;
    min-width: 38px;
    border-radius: 50%;
    background: var(--color-text);
    color: var(--color-bg);
    font-size: 0.8rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
  }
    color: var(--color-bg);
    font-size: 0.8rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .cb-wrapper .cb-online-dot {
    position: absolute;
    bottom: 1px;
    right: 1px;
    width: 10px;
    height: 10px;
    background: #22c55e;
    border-radius: 50%;
    border: 2px solid var(--color-bg-secondary);
    display: block;
  }
  .cb-wrapper .cb-header-meta { flex: 1; min-width: 0; }
  .cb-wrapper .cb-header-name {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.2;
    margin: 0;
    padding: 0;
  }
  .cb-wrapper .cb-header-status {
    font-size: 0.7rem;
    color: #22c55e;
    font-weight: 500;
    margin-top: 2px;
    padding: 0;
    transition: color 0.2s;
  }
  .cb-wrapper .cb-header-status.typing { color: var(--color-text-muted); }
  .cb-wrapper .cb-header-close {
    background: none;
    border: none;
    color: var(--color-text-muted);
    cursor: pointer;
    padding: 0.3rem;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s, color 0.15s;
    flex-shrink: 0;
  }
  .cb-wrapper .cb-header-close:hover {
    background: var(--color-border);
    color: var(--color-text);
  }

  /* ── Messages ── */
  .cb-wrapper .cb-messages {
    flex: 1;
    min-height: 0;
    overflow-y: auto;
    padding: 0.875rem 0.875rem 0.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    scroll-behavior: smooth;
    background: var(--color-bg);
    margin: 0;
    list-style: none;
  }
  .cb-wrapper .cb-messages::-webkit-scrollbar { width: 4px; }
  .cb-wrapper .cb-messages::-webkit-scrollbar-track { background: transparent; }
  .cb-wrapper .cb-messages::-webkit-scrollbar-thumb {
    background: var(--color-border);
    border-radius: 4px;
  }

  /* Date chip */
  .cb-wrapper .cb-date-chip {
    text-align: center;
    font-size: 0.68rem;
    color: var(--color-text-muted);
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin: 0.25rem 0 0.75rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .cb-wrapper .cb-date-chip::before,
  .cb-wrapper .cb-date-chip::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--color-border);
    display: block;
  }

  /* ── Message rows ── */
  :global(.cb-row) {
    display: flex;
    margin-top: 0.2rem;
    padding: 0;
    animation: cbIn 0.18s ease;
  }
  :global(.cb-row-in)  { justify-content: flex-start; }
  :global(.cb-row-out) { justify-content: flex-end; }

  @keyframes cbIn {
    from { opacity: 0; transform: translateY(6px) scale(0.97); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }

  /* ── Bubbles ── */
  :global(.cb-bub) {
    max-width: 78%;
    padding: 0.5rem 0.75rem 0.3rem;
    font-size: 0.875rem;
    line-height: 1.5;
    word-break: break-word;
    margin: 0;
    box-sizing: border-box;
    display: block;
  }
  /* AI — left, sharp top-left */
  :global(.cb-bub-in) {
    background: var(--color-bg-secondary) !important;
    color: var(--color-text) !important;
    border: 1px solid var(--color-border) !important;
    border-radius: 4px 16px 16px 16px !important;
  }
  /* User — right, sharp top-right */
  :global(.cb-bub-out) {
    background: var(--color-text) !important;
    color: var(--color-bg) !important;
    border: none !important;
    border-radius: 16px 4px 16px 16px !important;
  }
  /* Owner (Loui) — blue, left, sharp top-left */
  :global(.cb-bub-owner) {
    background: #2563eb !important;
    color: #ffffff !important;
    border: none !important;
    border-radius: 4px 16px 16px 16px !important;
  }
  /* Owner label */
  :global(.cb-owner-label) {
    display: block !important;
    font-size: 0.62rem !important;
    font-weight: 700 !important;
    letter-spacing: 0.06em !important;
    text-transform: uppercase !important;
    opacity: 0.8;
    margin-bottom: 3px !important;
  }
  /* Timestamp */
  :global(.cb-time) {
    display: block !important;
    font-size: 0.62rem !important;
    line-height: 1.2 !important;
    opacity: 0.45;
    text-align: right;
    margin-top: 0.25rem;
  }

  /* ── Typing indicator ── */
  .cb-wrapper .cb-typing-row {
    padding: 0 0.875rem 0.5rem;
    flex-shrink: 0;
    animation: cbIn 0.18s ease;
  }
  .cb-wrapper .cb-typing-pill {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 4px 14px 14px 14px;
    padding: 0.55rem 0.875rem;
    height: 36px;
  }
  .cb-wrapper .cb-typing-pill span {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-text-muted);
    display: block;
    animation: cbDot 1.3s infinite ease-in-out;
  }
  .cb-wrapper .cb-typing-pill span:nth-child(2) { animation-delay: 0.18s; }
  .cb-wrapper .cb-typing-pill span:nth-child(3) { animation-delay: 0.36s; }
  @keyframes cbDot {
    0%, 55%, 100% { transform: translateY(0);    opacity: 0.4; }
    27%           { transform: translateY(-5px); opacity: 1;   }
  }

  /* ── Input bar ── */
  .cb-wrapper .cb-input-bar {
    padding: 0.625rem 0.75rem;
    border-top: 1px solid var(--color-border);
    background: var(--color-bg-secondary);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
  }
  .cb-wrapper .cb-input {
    flex: 1;
    min-width: 0;
    background: var(--color-bg) !important;
    border: 1px solid var(--color-border) !important;
    border-radius: 22px !important;
    padding: 0.5rem 1rem !important;
    font-size: 0.875rem !important;
    color: var(--color-text) !important;
    font-family: inherit !important;
    outline: none !important;
    box-shadow: none !important;
    appearance: none;
    -webkit-appearance: none;
    transition: border-color 0.2s;
  }
  .cb-wrapper .cb-input:focus {
    border-color: var(--color-text-muted) !important;
    box-shadow: none !important;
    outline: none !important;
  }
  .cb-wrapper .cb-input::placeholder {
    color: var(--color-text-muted) !important;
    opacity: 1;
  }
  .cb-wrapper .cb-send {
    width: 38px;
    height: 38px;
    min-width: 38px;
    background: var(--color-text) !important;
    color: var(--color-bg) !important;
    border: none !important;
    border-radius: 50% !important;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    padding: 0;
    padding-left: 2px;
    box-shadow: none;
    transition: opacity 0.15s, transform 0.15s;
  }
  .cb-wrapper .cb-send:hover    { opacity: 0.78; transform: scale(1.07); }
  .cb-wrapper .cb-send:disabled { opacity: 0.3 !important; cursor: not-allowed; transform: none; }

  /* ── Mobile ── */
  @media (max-width: 480px) {
    .cb-wrapper {
      bottom: 1rem !important;
      right: 1rem !important;
    }
    .cb-wrapper .cb-toggle {
      width: 50px;
      height: 50px;
      padding: 0.6rem;
    }
    .cb-wrapper .cb-toggle-text {
      display: none;
    }
    .cb-wrapper .cb-toggle-icon {
      display: block !important;
    }
    .cb-wrapper .cb-window {
      width: calc(100vw - 2rem);
      right: -0.75rem;
      height: calc(100vh - 180px);
      max-height: 470px;
      bottom: 60px;
    }
  }

  /* Tablet */
  @media (min-width: 481px) and (max-width: 768px) {
    .cb-wrapper {
      bottom: 1.25rem !important;
      right: 1.25rem !important;
    }
    .cb-wrapper .cb-toggle {
      padding: 0.6rem 1rem;
    }
    .cb-wrapper .cb-toggle-text {
      display: none;
    }
    .cb-wrapper .cb-window {
      width: 350px;
      height: calc(100vh - 200px);
      max-height: 500px;
      bottom: 60px;
      right: 0;
    }
  }

  /* Extra small screens */
  @media (max-width: 360px) {
    .cb-wrapper {
      bottom: 0.75rem !important;
      right: 0.75rem !important;
    }
    .cb-wrapper .cb-window {
      width: calc(100vw - 1.5rem);
      right: -0.5rem;
    }
  }
</style>

<script is:inline>
  // Initialize chatbot when DOM is ready
  (function() {
    const toggleBtn = document.getElementById('cb-toggle');
    const cbWindow  = document.getElementById('cb-window');
    const closeBtn  = document.getElementById('cb-close');
    const sendBtn   = document.getElementById('cb-send');
    const inputEl   = document.getElementById('cb-input');
    const msgsEl    = document.getElementById('cb-messages');
    const typingEl  = document.getElementById('cb-typing');
    const statusEl  = document.getElementById('cb-status');
    const unreadEl  = document.getElementById('cb-unread');
    const iconOpen  = document.getElementById('cb-icon-open');
    const iconClose = document.getElementById('cb-icon-close');

    // Guard: essential elements must exist
    if (!toggleBtn || !cbWindow || !sendBtn || !inputEl) return;

    let isOpen = false;
    let ownerPollInterval = null;

    function nowTime() {
      return new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
    }

    function openChat() {
      isOpen = true;
      cbWindow.classList.add('open');
      cbWindow.setAttribute('aria-hidden', 'false');
      iconOpen.style.display  = 'none';
      iconClose.style.display = 'block';
      unreadEl.style.display  = 'none';
      setTimeout(() => inputEl.focus(), 230);
    }
    function closeChat() {
      isOpen = false;
      cbWindow.classList.remove('open');
      cbWindow.setAttribute('aria-hidden', 'true');
      iconOpen.style.display  = 'block';
      iconClose.style.display = 'none';
    }

    toggleBtn.addEventListener('click', () => isOpen ? closeChat() : openChat());
    closeBtn.addEventListener('click', closeChat);

    // role: 'in' = AI | 'out' = user | 'owner' = Loui (blue)
    function addBubble(text, role) {
      const row = document.createElement('div');
      row.className = `cb-row ${role === 'out' ? 'cb-row-out' : 'cb-row-in'}`;

      const bub = document.createElement('div');
      bub.className = `cb-bub ${
        role === 'out'   ? 'cb-bub-out'   :
        role === 'owner' ? 'cb-bub-owner' :
        'cb-bub-in'
      }`;

      if (role === 'owner') {
        const label = document.createElement('span');
        label.className = 'cb-owner-label';
        label.textContent = 'Loui';
        bub.appendChild(label);
      }

      const textNode = document.createElement('span');
      textNode.innerHTML = text.replace(/\n/g, '<br>');
      bub.appendChild(textNode);

      const time = document.createElement('span');
      time.className = 'cb-time';
      time.textContent = nowTime();
      bub.appendChild(time);

      row.appendChild(bub);
      msgsEl.appendChild(row);
      msgsEl.scrollTop = msgsEl.scrollHeight;

      if (!isOpen && role !== 'out') {
        unreadEl.style.display = 'block';
      }
    }

    function setTyping(show) {
      typingEl.style.display = show ? 'block' : 'none';
      sendBtn.disabled = show;
      statusEl.textContent = show ? 'typing...' : 'online';
      statusEl.classList.toggle('typing', show);
      if (show) msgsEl.scrollTop = msgsEl.scrollHeight;
    }

    // Start persistent polling for Loui's replies (runs as long as page is open)
    function startOwnerPoll(sessionId) {
      if (ownerPollInterval) clearInterval(ownerPollInterval);
      ownerPollInterval = setInterval(async () => {
        try {
          const res = await fetch(`/api/reply?sessionId=${sessionId}`);
          const data = await res.json();
          if (data.reply) {
            addBubble(data.reply, 'owner');
          }
        } catch (_) {}
      }, 3000);
    }

    // Persistent session ID for this browser tab
    const sessionId = sessionStorage.getItem('chatSessionId') || crypto.randomUUID();
    sessionStorage.setItem('chatSessionId', sessionId);

    // Start polling for owner replies immediately on page load
    startOwnerPoll(sessionId);

    async function sendMessage() {
      const text = inputEl.value.trim();
      if (!text || sendBtn.disabled) return;

      addBubble(text, 'out');
      inputEl.value = '';
      setTyping(true);

      try {
        // Step 1: Send message to server + notify Loui on Telegram
        await fetch('/api/chat', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ message: text, sessionId }),
        });

        // Step 2: AI replies immediately — no waiting for Loui
        const res = await fetch('/api/ai-fallback', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ message: text }),
        });
        const data = await res.json();
        setTyping(false);
        addBubble(data.reply || "Sorry, I'm having trouble right now.", 'in');

        // Loui's reply will appear automatically via the background poll (startOwnerPoll)

      } catch (err) {
        setTyping(false);
        addBubble("Sorry, I'm having trouble connecting right now.", 'in');
        console.error('ChatBot error:', err);
      }
    }

    sendBtn.addEventListener('click', sendMessage);
    inputEl.addEventListener('keydown', e => {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        sendMessage();
      }
    });
  })();
</script>